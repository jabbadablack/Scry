# ScryConfig.cmake — Build-tree-only package configuration for Scry.
#
# Usage (same machine, pointing at the build directory):
#   cmake -DScry_DIR=<build_dir> ...
#
# Note: this config targets the build tree.  Cross-machine deployment
# requires a proper cmake --install step (not yet wired up).

get_filename_component(_SCRY_CONFIG_DIR "${CMAKE_CURRENT_LIST_FILE}" DIRECTORY)

# Import the scry shared-library target
include("${_SCRY_CONFIG_DIR}/ScryTargets.cmake")

# Expose helper macros (scry_add_plugin, etc.) to the consuming project
include("${_SCRY_CONFIG_DIR}/cmake/ScryHelpers.cmake")

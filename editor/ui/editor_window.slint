import { Button, ScrollView, ListView } from "std-widgets.slint";

// Reusable dark panel header strip
component PanelHeader inherits Rectangle {
    in property <string> title;
    height: 24px;
    background: #2a2a2a;
    border-width: 0px;
    border-color: #3a3a3a;

    Text {
        x: 8px;
        y: (parent.height - self.height) / 2;
        text: parent.title;
        color: #aaaaaa;
        font-size: 11px;
        font-weight: 600;
    }
}

// A single row in the entity outliner
component OutlinerItem inherits Rectangle {
    in property <string> label;
    in property <bool> selected: false;
    callback clicked();

    height: 22px;
    background: selected ? #2e4a6e : transparent;

    TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.clicked(); }
    }

    Text {
        x: 20px;
        y: (parent.height - self.height) / 2;
        text: root.label;
        color: root.selected ? #ffffff : #cccccc;
        font-size: 12px;
    }
}

// A name/value row in the Inspector
component InspectorRow inherits Rectangle {
    in property <string> label;
    in property <string> value;

    height: 24px;
    background: transparent;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 4px;

        Text {
            text: root.label;
            color: #888888;
            font-size: 11px;
            width: 90px;
            vertical-alignment: center;
        }

        Rectangle {
            background: #1e1e1e;
            border-width: 1px;
            border-color: #3a3a3a;
            border-radius: 2px;

            Text {
                x: 6px;
                y: (parent.height - self.height) / 2;
                text: root.value;
                color: #dddddd;
                font-size: 11px;
            }
        }
    }
}

// Menu bar button with hover highlight
component MenuButton inherits Rectangle {
    in property <string> label;
    callback clicked();

    width: label.character-count * 9px + 16px;
    height: 100%;
    background: touch.has-hover ? #3a3a3a : transparent;

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    Text {
        x: 8px;
        y: (parent.height - self.height) / 2;
        text: root.label;
        color: #cccccc;
        font-size: 12px;
    }
}

export component EditorWindow inherits Window {
    title: "SCRY Editor";
    preferred-width: 1400px;
    preferred-height: 800px;
    background: #1a1a1a;

    // The offscreen 3D viewport image, fed each frame by RendererBridge
    in-out property <image> viewport-image;

    // Currently selected entity name (updated by EditorLogicModule)
    in-out property <string> selected-entity: "";

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        // ── Menu Bar ──────────────────────────────────────────────────────────
        Rectangle {
            height: 28px;
            background: #2d2d2d;

            HorizontalLayout {
                padding-left: 4px;
                padding-right: 4px;
                spacing: 0px;
                alignment: start;

                MenuButton { label: "File"; }
                MenuButton { label: "Edit"; }
                MenuButton { label: "View"; }
                MenuButton { label: "Entity"; }
                MenuButton { label: "Help"; }
            }

            // Right-aligned engine status text
            Text {
                x: parent.width - self.width - 10px;
                y: (parent.height - self.height) / 2;
                text: "SCRY Engine";
                color: #555555;
                font-size: 11px;
            }
        }

        // Thin separator
        Rectangle { height: 1px; background: #111111; }

        // ── Main Content ──────────────────────────────────────────────────────
        HorizontalLayout {
            padding: 0px;
            spacing: 0px;

            // ── Left: Entity Outliner ─────────────────────────────────────────
            Rectangle {
                width: 240px;
                background: #222222;

                VerticalLayout {
                    padding: 0px;
                    spacing: 0px;

                    PanelHeader { title: "Entity Outliner"; }

                    Rectangle { height: 1px; background: #111111; }

                    // Search bar
                    Rectangle {
                        height: 28px;
                        background: #1e1e1e;

                        Text {
                            x: 8px;
                            y: (parent.height - self.height) / 2;
                            text: "Filter...";
                            color: #555555;
                            font-size: 11px;
                        }
                    }

                    Rectangle { height: 1px; background: #111111; }

                    // Entity list (static scaffold — populated via C++ callbacks)
                    ScrollView {
                        OutlinerItem {
                            label: "Level";
                            selected: root.selected-entity == "Level";
                            clicked => { root.selected-entity = "Level"; }
                        }

                        OutlinerItem {
                            label: "  Grid";
                            selected: root.selected-entity == "Grid";
                            clicked => { root.selected-entity = "Grid"; }
                        }

                        OutlinerItem {
                            label: "  Camera";
                            selected: root.selected-entity == "Camera";
                            clicked => { root.selected-entity = "Camera"; }
                        }
                    }
                }
            }

            Rectangle { width: 1px; background: #111111; }

            // ── Centre: 3D Viewport ───────────────────────────────────────────
            Rectangle {
                background: #0f0f0f;
                horizontal-stretch: 1;

                Image {
                    source: root.viewport-image;
                    width: 100%;
                    height: 100%;
                    image-fit: contain;
                }

                // Overlay: viewport resolution badge
                if root.viewport-image.width > 0: Rectangle {
                    x: parent.width - self.width - 8px;
                    y: 8px;
                    width: 90px;
                    height: 20px;
                    background: #00000099;
                    border-radius: 3px;

                    Text {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        text: "\{root.viewport-image.width}×\{root.viewport-image.height}";
                        color: #888888;
                        font-size: 10px;
                    }
                }
            }

            Rectangle { width: 1px; background: #111111; }

            // ── Right: Inspector ──────────────────────────────────────────────
            Rectangle {
                width: 280px;
                background: #222222;

                VerticalLayout {
                    padding: 0px;
                    spacing: 0px;

                    PanelHeader { title: "Inspector"; }

                    Rectangle { height: 1px; background: #111111; }

                    // Entity header
                    Rectangle {
                        height: 36px;
                        background: #1e1e1e;

                        Text {
                            x: 10px;
                            y: (parent.height - self.height) / 2;
                            text: root.selected-entity != "" ? root.selected-entity : "(no selection)";
                            color: root.selected-entity != "" ? #eeeeee : #555555;
                            font-size: 13px;
                            font-weight: 600;
                        }
                    }

                    Rectangle { height: 1px; background: #111111; }

                    // Component sections
                    if root.selected-entity != "": VerticalLayout {
                        padding: 0px;
                        spacing: 0px;

                        // Transform component
                        PanelHeader { title: "Transform"; }
                        InspectorRow { label: "Position X"; value: "0.000"; }
                        InspectorRow { label: "Position Y"; value: "0.000"; }
                        InspectorRow { label: "Position Z"; value: "0.000"; }

                        Rectangle { height: 1px; background: #111111; }

                        PanelHeader { title: "Render"; }
                        InspectorRow { label: "Mesh"; value: "GridMesh"; }
                        InspectorRow { label: "Texture"; value: "(none)"; }
                    }
                }
            }
        }

        // ── Status Bar ────────────────────────────────────────────────────────
        Rectangle {
            height: 1px;
            background: #111111;
        }

        Rectangle {
            height: 22px;
            background: #1d3a5e;

            Text {
                x: 8px;
                y: (parent.height - self.height) / 2;
                text: "Ready";
                color: #aaaaaa;
                font-size: 11px;
            }
        }
    }
}
